# App
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# CORS — pisahkan dengan koma jika lebih dari satu origin
CORS_ORIGINS=http://localhost:3000,https://tcm.my.id

# JWT
JWT_SECRET=tcm-jwt-secret-dev-change-in-prod
JWT_REFRESH_SECRET=tcm-refresh-secret-dev-change-in-prod

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tcm_db

# Redis
REDIS_URL=redis://localhost:6379

# Google OAuth (isi jika sudah punya credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Agent
AGENT_API_KEY=tcm-agent-dev-key-paperclip

# Brevo transactional email
BREVO_API_KEY=
BREVO_SENDER_EMAIL=info@tcm.my.id
BREVO_SENDER_NAME=TCM Indonesia

# Phase 2B — kosongkan dulu, jangan error jika tidak ada
ANTHROPIC_API_KEY=
RESEND_API_KEY=
EMAIL_FROM=noreply@tcm.my.id
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=tcm-media
R2_PUBLIC_URL=
MEILI_URL=http://localhost:7700
MEILI_API_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
